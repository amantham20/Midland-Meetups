rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Admin access:
    // 1) custom claim admin == true (preferred long-term), OR
    // 2) hard-coded bootstrap UIDs (first organizers — keep in sync with NEXT_PUBLIC_ADMIN_UIDS)
    function isBootstrapAdmin() {
      return signedIn() && request.auth.uid in [
        'HrTrYtRdntX7pesO72lRAVnPTZC2'
      ];
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        isBootstrapAdmin()
      );
    }

    match /events/{eventId} {
      allow read: if resource.data.approved == true || isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.approved == false
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll([
          'title', 'host', 'date', 'time', 'location', 'description',
          'status', 'statusNote', 'approved', 'createdBy'
        ]);
      allow update, delete: if isAdmin();
    }

    match /memories/{memoryId} {
      allow read: if resource.data.approved == true || isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.approved == false
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /squad/{memberId} {
      function squadEmailMatches() {
        return signedIn()
          && request.auth.token.email is string
          && resource.data.email is string
          && resource.data.email == request.auth.token.email.lower();
      }

      function ownsSquad() {
        return signedIn() && (
          resource.data.createdBy == request.auth.uid
          || squadEmailMatches()
        );
      }

      allow read: if resource.data.approved == true || isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid)
        || squadEmailMatches();

      // Photos are compressed base64 on the document (no Cloud Storage).
      allow create: if signedIn()
        && request.resource.data.approved == false
        && request.resource.data.createdBy == request.auth.uid
        && (!('photoBase64' in request.resource.data)
            || request.resource.data.photoBase64.size() < 350000);

      // Admins: full edit. Owners (by uid or matching email): edit profile but not approval.
      allow update: if isAdmin()
        || (ownsSquad()
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.createdBy == request.auth.uid
          && (!('photoBase64' in request.resource.data)
              || request.resource.data.photoBase64.size() < 350000));

      allow delete: if isAdmin();
    }

    match /rsvps/{rsvpId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && rsvpId == request.auth.uid + '_' + request.resource.data.eventId
        && request.resource.data.status in ['going', 'not-going'];
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /fcmTokens/{tokenId} {
      allow read: if isAdmin();
      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    // Audience groups (tags): emails → who can see tagged events.
    // Signed-in users read so the client can filter; only admins write.
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
